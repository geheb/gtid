root = true

[*.rs]
indent_style = space
indent_size = 4
max_width = 100
hard_tabs = false
tab_spaces = 4
newline_style = Unix
use_small_heuristics = "Default"
reorder_imports = true
reorder_modules = true
remove_nested_parens = true
format_strings = true
normalize_comments = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
max_width = 80